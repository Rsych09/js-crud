<div class="alert">
    <div class="alert__menu">
        <div class="alert__flex">
            <h6 class="alert__title">{{data.message}}</h6>
            <span class="alert__description">{{data.info}}</span>
        </div>
        <a href="{{data.link}}" class="alert__button">Повернутися назад</a>
    </div>
</div>

