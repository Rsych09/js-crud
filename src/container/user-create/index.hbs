<main class="main">
    {{#with data}}
    <form method="post" action="/user-submit?id={{id}}" class="form-card">
        {{> heading title="Ваше замовлення"}}

        <ul class="cart">
            {{#each cart}}
            <li class="cart_item">
                <span>{{text}}</span>
                <span>{{price}} грн</span>
            </li>
            {{/each}}
        </ul>

        <hr>

        {{>heading title="Оформити замовлення"}}

        {{>field label="Ім'я" name="firstname"}}
        {{>field label="Прізвище" name="lastname"}}
        {{>field label="Телефон" name="phone"}}
        {{>field label="Пошта" name="email"}}
        {{>field label="Коментар" name="comment"}}
        {{>field label="Списати бонуси" name="bonus"}}

        <hr>
        {{>field value=totalPrice name="totalPrice" disabled=true}}
        {{>field value=productPrice name="totalPrice" disabled=true}}
        {{>field value=deliveryPrice name="totalPrice" disabled=true}}

        <strong class="form-cart__total">
            Всього: {{totalPrice}} грн ({{bonus}} грн бонусів)
        </strong>

        {{>button text="Оформити замовлення"}}



    </form>
    {{/with}}
</main>